local wezterm = require("wezterm")

local config = {
	default_prog = { "nu" },
	color_scheme = "Ayu Mirage",
	tab_bar_at_bottom = true,
	window_decorations = "RESIZE",
	use_fancy_tab_bar = false,
	max_fps = 120,
	window_padding = {
		left = 12,
		right = 12,
		top = 0,
		bottom = 0,
	},
	font_size = 16.0,
	launch_menu = {},
	keys = {},
	set_environment_variables = {},
}

{{ if eq .chezmoi.os "windows" -}}
table.insert(config.launch_menu, { label = "powershell", args = { "pwsh.exe", "-nologo" } })
{{ if eq .chezmoi.username "p_dydyshka" -}}
table.insert(
  config.launch_menu,
  { label = "wotdevtool", args = { os.getenv("USERPROFILE") .. "/wotdevtool/menu.cmd" } }
)
{{ end -}}
{{ end }}

{{ if eq .chezmoi.hostname "solus" -}}
config.check_for_updates = false  -- because on solus it is built from source
{{ end }}

table.insert(config.launch_menu, { label = "Julia", args = { "julia" } })

table.insert(config.keys, { key = "l", mods = "ALT", action = wezterm.action.ShowLauncher })

local bar = wezterm.plugin.require("https://github.com/adriankarlen/bar.wezterm")
bar.apply_to_config(config)

return config
