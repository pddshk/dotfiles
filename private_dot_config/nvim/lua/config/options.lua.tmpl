vim.g.mapleader = " "
vim.g.maplocalleader = "\\"

vim.opt.clipboard = vim.env.SSH_CONNECTION and "" or "unnamedplus" -- Sync with system clipboard
vim.opt.confirm = true -- Confirm to save changes before exiting modified buffer
vim.opt.cursorline = true -- Enable highlighting of the current line
vim.opt.list = false
vim.opt.listchars = {
  tab = '→ ',
  space = '·',
  trail = '•',
  eol = '↵',
}

vim.opt.fillchars = {
  foldopen = "",
  foldclose = "",
  fold = " ",
  foldsep = " ",
  diff = "╱",
  eob = " ",
}
vim.opt.foldlevel = 99
vim.opt.foldmethod = "indent"
vim.opt.foldtext = ""

vim.opt.number = true
vim.opt.relativenumber = true

vim.opt.shiftwidth = 4
vim.opt.tabstop = 4
vim.opt.expandtab = true -- Use spaces instead of tabs
vim.opt.smartindent = true

vim.opt.ignorecase = true
vim.opt.smartcase = true

vim.opt.smoothscroll = true
vim.opt.splitbelow = true
vim.opt.splitright = true
vim.opt.termguicolors = true -- True color support
vim.opt.undofile = true
vim.opt.undolevels = 10000
vim.opt.wrap = true

{{ if eq .chezmoi.os "windows" -}}
vim.o.shellcmdflag = '-c'  -- neovim defaults to /s /c on windows
vim.o.shellquote = ''
vim.o.shellxquote = ''
{{ if eq .chezmoi.username "CORP\\p_dydyshka" -}}
vim.g.python3_host_prog = "C:/Python313/python.exe"
vim.g.autoformat = false
vim.filetype.add({ extension = { as = "actionscript" } })
vim.filetype.add({ extension = { def = "xml" } })
vim.filetype.add({ extension = { prefab = "xml" } })
